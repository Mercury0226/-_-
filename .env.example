# API Keys
UJM_API_KEY=your_ingest_api_key
VISION_MODEL_API_KEY=your_cv_api_key
LLM_API_KEY=your_llm_api_key

# Database
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=ujm_analyzer
MONGODB_COLLECTION=behavior_logs
REDIS_URL=redis://localhost:6379/0

# Server
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
CORS_ORIGINS=http://localhost:5173
UTF8_FORCE=true

# SDK
SDK_INGEST_ENDPOINT=http://localhost:8000/api/v1/logs/ingest
SDK_FLUSH_INTERVAL_MS=5000
SDK_MAX_BUFFER=20
